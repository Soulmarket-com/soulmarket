---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getLangFromUrl, useTranslations, withBase, translatePath } from '../i18n/utils';

interface Props {
  title: string;
  description: string;
  image?: string;
  lang?: 'es' | 'en';
  type?: 'website' | 'article';
  noindex?: boolean;
}

const { title, description, image = '/og-default.png', lang, type = 'website', noindex = false } = Astro.props;

const resolvedLang = lang ?? getLangFromUrl(Astro.url);
const t = useTranslations(resolvedLang);
const siteUrl = 'https://soulmarket.com';

// Canonical y hreflang apuntan SIEMPRE a producción: si el build lleva base
// (preview de GitHub Pages) se retira del pathname y se añade noindex.
const basePrefix = import.meta.env.BASE_URL.replace(/\/+$/, '');
const isPreview = basePrefix !== '';
const sitePath = isPreview && Astro.url.pathname.startsWith(basePrefix)
  ? Astro.url.pathname.slice(basePrefix.length) || '/'
  : Astro.url.pathname;

const canonical = new URL(sitePath, siteUrl).href;
const ogImage = image.startsWith('http') ? image : new URL(image, siteUrl).href;
const fullTitle = title.includes('Soulmarket') ? title : `${title} | Soulmarket`;

// Solo se emiten alternates cuando existe la página equivalente traducida;
// en detalles de blog/portfolio (slugs distintos por idioma) se omiten.
const stripBase = (p: string | null) =>
  p === null ? null : (isPreview && p.startsWith(basePrefix) ? p.slice(basePrefix.length) || '/' : p);
const esPath = stripBase(translatePath(Astro.url.pathname, 'es'));
const enPath = stripBase(translatePath(Astro.url.pathname, 'en'));

const schema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'ProfessionalService',
  name: 'Soulmarket',
  url: siteUrl,
  email: 'hola@soulmarket.com',
  description: resolvedLang === 'es'
    ? 'Diseño web, fotografía, video y marketing digital para marcas que quieren destacar.'
    : 'Web design, photography, video and digital marketing for brands that want to stand out.',
  founder: { '@type': 'Person', name: 'José Miguel Díaz' },
  employee: [
    { '@type': 'Person', name: 'José Miguel Díaz', jobTitle: 'Development & Technical Direction' },
    { '@type': 'Person', name: 'Marcela Talero', jobTitle: 'Marketing & Communications' },
    { '@type': 'Person', name: 'Sergio Guild', jobTitle: 'Audiovisual Direction' },
  ],
  knowsLanguage: ['es', 'en'],
  serviceType: ['Web Design', 'Graphic Design', 'Photography', 'Digital Marketing'],
});
---

<!doctype html>
<html lang={resolvedLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#FAF6EF" />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {(noindex || isPreview) && <meta name="robots" content="noindex, nofollow" />}

    <meta property="og:type" content={type} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="Soulmarket" />
    <meta property="og:locale" content={resolvedLang === 'es' ? 'es_ES' : 'en_US'} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    {esPath && enPath && (
      <>
        <link rel="alternate" hreflang="es" href={`${siteUrl}${esPath}`} />
        <link rel="alternate" hreflang="en" href={`${siteUrl}${enPath}`} />
        <link rel="alternate" hreflang="x-default" href={`${siteUrl}${esPath}`} />
      </>
    )}

    <link rel="icon" type="image/svg+xml" href={withBase('/favicon.svg')} />
    <link rel="icon" href={withBase('/favicon.ico')} sizes="any" />

    <script type="application/ld+json" set:html={schema} />
  </head>
  <body>
    <a href="#main" class="skip-link">{t('skip.content')}</a>
    <Header lang={resolvedLang} />
    <main id="main">
      <slot />
    </main>
    <Footer lang={resolvedLang} />

    <script>
      // Scroll-reveal: toggles `.is-visible` on any `.reveal` element once it
      // enters the viewport. Pairs with the fadeIn*/reveal CSS in global.css.
      const observer = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              observer.unobserve(entry.target);
            }
          }
        },
        { threshold: 0.15, rootMargin: '0px 0px -10% 0px' }
      );

      function observeReveals() {
        document.querySelectorAll('.reveal:not(.is-visible)').forEach((el) => observer.observe(el));
      }

      observeReveals();
      // Re-run if View Transitions is ever enabled for this project.
      document.addEventListener('astro:page-load', observeReveals);
    </script>

    <script>
      import { initScrollAnimations } from '../scripts/scroll-animations';
      initScrollAnimations();
    </script>
  </body>
</html>

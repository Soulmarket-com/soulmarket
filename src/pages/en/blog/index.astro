---
import Base from '../../../layouts/Base.astro';
import BlogRows from '../../../components/sections/BlogRows.astro';
import CtaBanner from '../../../components/sections/CtaBanner.astro';
import { getBlogPosts } from '../../../lib/strapi';
import { useTranslations } from '../../../i18n/utils';

const lang = 'en';
const t = useTranslations(lang);

// El contenido de Strapi todavía no tiene i18n (solo ES) — se muestra el
// mismo contenido bajo /en/ hasta que se traduzca. Ver soulmarket/CLAUDE.md.
const posts = await getBlogPosts();
---

<Base
  title="Web design and digital marketing blog"
  description="Articles, guides and resources on web design, SEO, photography and digital marketing for freelancers and small businesses."
  lang={lang}
>
  <header class="hero-columns relative overflow-hidden pt-28 md:pt-36 pb-8 md:pb-12">
    <div class="container-lg relative">
      <h1 class="reveal fadeInUp giant-heading text-ink mb-0">
        <em class="block">{t('blog.page.italic')}</em>
        <span class="block">{t('blog.page.main')}</span>
      </h1>
    </div>
  </header>

  <section class="pb-20 md:pb-28">
    <div class="container-lg">
      <BlogRows lang={lang} posts={posts} />
    </div>
  </section>

  <CtaBanner lang={lang} />
</Base>

---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getLangFromUrl, useTranslations } from '../i18n/utils';

interface Props {
  title: string;
  description: string;
  image?: string;
  lang?: 'es' | 'en';
  type?: 'website' | 'article';
  noindex?: boolean;
}

const { title, description, image = '/og-default.jpg', lang, type = 'website', noindex = false } = Astro.props;

const resolvedLang = lang ?? getLangFromUrl(Astro.url);
const t = useTranslations(resolvedLang);
const siteUrl = 'https://soulmarket.com';
const canonical = new URL(Astro.url.pathname, siteUrl).href;
const ogImage = image.startsWith('http') ? image : new URL(image, siteUrl).href;
const fullTitle = title.includes('Soulmarket') ? title : `${title} | Soulmarket`;

const esPath = Astro.url.pathname.startsWith('/en')
  ? Astro.url.pathname.replace(/^\/en/, '') || '/'
  : Astro.url.pathname;
const enPath = Astro.url.pathname.startsWith('/en')
  ? Astro.url.pathname
  : `/en${Astro.url.pathname}`;

const schema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'ProfessionalService',
  name: 'Soulmarket',
  url: siteUrl,
  email: 'hola@soulmarket.com',
  description: resolvedLang === 'es'
    ? 'Diseño web, fotografía, video y marketing digital para marcas que quieren destacar.'
    : 'Web design, photography, video and digital marketing for brands that want to stand out.',
  founder: { '@type': 'Person', name: 'José Miguel Díaz' },
  employee: [
    { '@type': 'Person', name: 'José Miguel Díaz', jobTitle: 'Development & Technical Direction' },
    { '@type': 'Person', name: 'Marcela Talero', jobTitle: 'Marketing & Communications' },
    { '@type': 'Person', name: 'Sergio Guild', jobTitle: 'Audiovisual Direction' },
  ],
  knowsLanguage: ['es', 'en'],
  serviceType: ['Web Design', 'Graphic Design', 'Photography', 'Digital Marketing'],
});
---

<!doctype html>
<html lang={resolvedLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#FAF6EF" />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <meta property="og:type" content={type} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="Soulmarket" />
    <meta property="og:locale" content={resolvedLang === 'es' ? 'es_ES' : 'en_US'} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="alternate" hreflang="es" href={`${siteUrl}${esPath}`} />
    <link rel="alternate" hreflang="en" href={`${siteUrl}${enPath}`} />
    <link rel="alternate" hreflang="x-default" href={`${siteUrl}${esPath}`} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" sizes="any" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400..900;1,9..144,400..600&family=Instrument+Sans:ital,wght@0,400..700;1,400..700&display=swap" rel="stylesheet" />

    <script type="application/ld+json" set:html={schema} />
  </head>
  <body>
    <a href="#main" class="skip-link">{t('skip.content')}</a>
    <Header lang={resolvedLang} />
    <main id="main">
      <slot />
    </main>
    <Footer lang={resolvedLang} />

    <script>
      // Scroll-reveal: toggles `.is-visible` on any `.reveal` element once it
      // enters the viewport. Pairs with the fadeIn*/reveal CSS in global.css.
      const observer = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              observer.unobserve(entry.target);
            }
          }
        },
        { threshold: 0.15, rootMargin: '0px 0px -10% 0px' }
      );

      function observeReveals() {
        document.querySelectorAll('.reveal:not(.is-visible)').forEach((el) => observer.observe(el));
      }

      observeReveals();
      // Re-run if View Transitions is ever enabled for this project.
      document.addEventListener('astro:page-load', observeReveals);
    </script>

    <script>
      import { initScrollAnimations } from '../scripts/scroll-animations';
      initScrollAnimations();
    </script>
  </body>
</html>

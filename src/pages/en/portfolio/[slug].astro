---
import { getCollection, render } from 'astro:content';
import Base from '../../../layouts/Base.astro';
import ProjectDetail from '../../../components/sections/ProjectDetail.astro';
import CtaBanner from '../../../components/sections/CtaBanner.astro';

export async function getStaticPaths() {
  const items = (await getCollection('portfolio', ({ data }) => data.lang === 'en'))
    .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
  return items.map((item, i) => ({
    params: { slug: item.id },
    props: { item, prev: items[i - 1] ?? null, next: items[i + 1] ?? null },
  }));
}

const { item, prev, next } = Astro.props;
const { Content } = await render(item);
const lang = 'en';
---

<Base
  title={item.data.title}
  description={item.data.description}
  image={item.data.image}
  lang={lang}
>
  <ProjectDetail lang={lang} item={item} prev={prev} next={next}>
    <Content />
  </ProjectDetail>
  <CtaBanner lang={lang} />
</Base>

---
import Base from '../../../layouts/Base.astro';
import CtaBanner from '../../../components/sections/CtaBanner.astro';
import { getCollection } from 'astro:content';
import { useTranslations } from '../../../i18n/utils';

const lang = 'en';
const t = useTranslations(lang);

const allItems = await getCollection('portfolio', ({ data }) => data.lang === lang);
const items = allItems.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const categoryMap: Record<string, string> = {
  web: t('portfolio.filter.web'),
  design: t('portfolio.filter.design'),
  'photo-video': t('portfolio.filter.media'),
  marketing: t('portfolio.filter.marketing'),
};
---

<Base
  title="Portfolio — Web design and digital projects"
  description="Web design, branding, photography and digital marketing projects. Real work with real results."
  lang="en"
>
  <header class="bg-ink text-white pt-28 pb-16">
    <div class="container-lg">
      <span class="text-accent-light text-xs font-semibold uppercase tracking-widest">{t('portfolio.eyebrow')}</span>
      <h1 class="text-4xl sm:text-5xl md:text-6xl font-extrabold mt-3 tracking-tight">{t('portfolio.title')}</h1>
    </div>
  </header>

  <section class="section-gap">
    <div class="container-lg">
      {items.length === 0 ? (
        <p class="text-center text-muted py-20">{t('portfolio.empty')}</p>
      ) : (
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {items.map((item) => (
            <a
              href={`/en/portfolio/${item.id}`}
              class="group block rounded-2xl overflow-hidden border border-border hover:border-transparent hover:shadow-xl transition-all duration-300"
            >
              <div class="aspect-[4/3] bg-surface overflow-hidden">
                <img src={item.data.image} alt={item.data.imageAlt || item.data.title}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
              </div>
              <div class="p-5">
                <span class="text-xs font-medium text-accent bg-accent/8 px-2.5 py-1 rounded-full">
                  {categoryMap[item.data.category]}
                </span>
                <h2 class="font-bold text-ink text-base leading-snug mt-2">{item.data.title}</h2>
                <p class="text-sm text-muted mt-1.5 line-clamp-2">{item.data.description}</p>
              </div>
            </a>
          ))}
        </div>
      )}
    </div>
  </section>

  <CtaBanner lang={lang} />
</Base>

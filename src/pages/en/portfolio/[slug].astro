---
import { marked } from 'marked';
import { getPortfolioItems } from '../../../lib/strapi';
import Base from '../../../layouts/Base.astro';
import ProjectDetail from '../../../components/sections/ProjectDetail.astro';
import CtaBanner from '../../../components/sections/CtaBanner.astro';

export async function getStaticPaths() {
  // El contenido de Strapi todavía no tiene i18n (solo ES) — ver soulmarket/CLAUDE.md.
  const items = await getPortfolioItems();
  return items.map((item, i) => ({
    params: { slug: item.id },
    props: { item, prev: items[i - 1] ?? null, next: items[i + 1] ?? null },
  }));
}

const { item, prev, next } = Astro.props;
const contentHtml = marked.parse(item.content);
const lang = 'en';
---

<Base
  title={item.data.title}
  description={item.data.description}
  image={item.data.image}
  lang={lang}
>
  <ProjectDetail lang={lang} item={item} prev={prev} next={next}>
    <Fragment set:html={contentHtml} />
  </ProjectDetail>
  <CtaBanner lang={lang} />
</Base>

---
// Visual only — no submit handler wired up. Connect to an email provider
// (Mailchimp, Brevo, etc.) before launch.
import { useTranslations } from '../../i18n/utils';

interface Props {
  lang: 'es' | 'en';
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section class="section-gap bg-surface">
  <div class="container-lg">
    <div class="reveal fadeInUp bg-white rounded-3xl border border-border p-10 md:p-16 text-center max-w-2xl mx-auto">
      <h2 class="section-title-small text-ink mb-8">{t('newsletter.title')}</h2>
      <form class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto">
        <input
          type="email"
          name="email"
          required
          autocomplete="email"
          spellcheck="false"
          aria-label={t('newsletter.placeholder')}
          placeholder={t('newsletter.placeholder')}
          class="flex-1 px-4 py-3 rounded-default border border-border text-sm focus:border-accent"
        />
        <button type="submit" class="btn-mod btn-grad justify-center">{t('newsletter.cta')}</button>
      </form>
      <p class="text-xs text-gray-1 mt-4">{t('newsletter.legal')}</p>
    </div>
  </div>
</section>

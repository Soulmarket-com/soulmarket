---
import Base from '../layouts/Base.astro';
import CtaBanner from '../components/sections/CtaBanner.astro';
import { useTranslations } from '../i18n/utils';

const lang = 'es';
const t = useTranslations(lang);
---

<Base
  title="Sobre mí — Diseñador web y fotógrafo freelance"
  description="Soy José Miguel, diseñador web y fotógrafo freelance. Conóceme y descubre cómo puedo ayudarte con tu proyecto digital."
  lang="es"
>
  <header class="bg-ink text-white pt-28 pb-16">
    <div class="container-lg">
      <span class="text-accent-light text-xs font-semibold uppercase tracking-widest">{t('about.eyebrow')}</span>
      <h1 class="text-4xl sm:text-5xl md:text-6xl font-extrabold mt-3 tracking-tight">{t('about.title')}</h1>
    </div>
  </header>

  <section class="section-gap">
    <div class="container-md">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-16 items-start">
        <!-- Photo placeholder -->
        <div class="aspect-[3/4] bg-surface rounded-2xl flex items-center justify-center text-7xl sticky top-24">
          🧑‍💻
        </div>

        <!-- Text -->
        <div>
          <h2 class="text-2xl font-extrabold text-ink mb-6">Hola, soy José Miguel</h2>
          <div class="prose-content space-y-4 text-muted text-base leading-relaxed">
            <p>
              Soy un profesional creativo con experiencia en diseño web, fotografía y marketing digital.
              Mi misión es ayudar a autónomos y pequeñas empresas a construir una presencia digital
              que refleje su esencia y les ayude a crecer.
            </p>
            <p>
              Empecé en el mundo del diseño gráfico y fui evolucionando hacia el desarrollo web y la
              fotografía profesional. Hoy ofrezco un servicio integral que abarca desde la imagen de
              marca hasta la estrategia digital.
            </p>
            <p>
              Lo que me diferencia es la combinación de sensibilidad artística con conocimiento técnico:
              hago webs que no solo son bonitas, sino que también funcionan, cargan rápido y posicionan bien.
            </p>
          </div>

          <!-- Skills -->
          <div class="mt-10">
            <h3 class="text-sm font-semibold uppercase tracking-widest text-muted mb-5">Habilidades</h3>
            <div class="flex flex-wrap gap-2">
              {['Astro.js', 'React', 'Tailwind CSS', 'WordPress', 'Figma', 'Adobe Photoshop', 'Lightroom', 'Final Cut Pro', 'SEO', 'Google Ads', 'Meta Ads'].map(skill => (
                <span class="text-sm bg-surface border border-border text-ink px-3 py-1.5 rounded-lg font-medium">
                  {skill}
                </span>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <CtaBanner lang={lang} />
</Base>

---
import { useTranslations, routes } from '../../i18n/utils';
import AnimatedButton from '../ui/AnimatedButton.astro';

interface Props {
  lang: 'es' | 'en';
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const r = routes[lang];
---

<section class="hero-columns relative overflow-hidden bg-paper min-h-svh flex flex-col">
  <!-- Doodle "alma": corazón garabateado a mano, detrás del titular -->
  <svg
    class="absolute top-[8%] right-[-6%] w-[52vw] max-w-3xl h-auto pointer-events-none select-none"
    viewBox="0 0 100 100" fill="none" aria-hidden="true"
  >
    <g stroke="var(--color-gray-light-4)" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round">
      <path d="M50 32 C 44 16, 22 12, 14 26 C 6 40, 16 56, 30 68 C 38 75, 46 82, 50 88 C 54 81, 63 74, 71 66 C 84 54, 94 39, 85 26 C 76 13, 55 17, 50 32 Z" />
      <path d="M50 35 C 45 21, 26 17, 19 28 C 12 39, 20 53, 32 64 C 39 70, 46 77, 50 83 C 55 76, 62 70, 69 63 C 80 52, 88 40, 81 29 C 73 18, 56 22, 50 35 Z" opacity="0.55" />
      <path d="M39 46 c 0.5 2.5, 0.5 4, 0 6.5" />
      <path d="M61 46 c 0.5 2.5, 0.5 4, 0 6.5" />
      <path d="M40 61 c 6 5.5, 14 5.5, 20 -0.5" />
    </g>
  </svg>

  <div class="container-lg relative flex-1 flex flex-col pt-24 md:pt-28 pb-16 w-full">
    <!-- Mini-lista de servicios, arriba a la derecha -->
    <div class="reveal fadeIn hidden md:block self-end text-right max-w-xs" style="--reveal-delay:0.5s">
      <p class="text-[11px] font-semibold uppercase tracking-[0.16em] text-ink">{t('hero.services.label')}</p>
      <p class="text-[11px] uppercase tracking-[0.14em] leading-relaxed text-muted mt-1">{t('hero.services.list')}</p>
    </div>

    <!-- Titular gigante -->
    <h1 class="hero-giant relative text-ink mt-10 md:mt-2 mb-0">
      <span class="reveal fadeInUp block" style="--reveal-delay:0.05s">
        {t('hero.giant.1')}<em class="hero-giant-em">{t('hero.giant.italic')}</em>
      </span>
      <span class="reveal fadeInUp block hero-giant-line2" style="--reveal-delay:0.18s">
        {t('hero.giant.2')}
      </span>
    </h1>

    <!-- Sello editorial giratorio, solapado con el titular -->
    <div class="reveal fadeIn absolute right-[4%] top-[38%] w-24 h-24 lg:w-28 lg:h-28 hidden sm:block" style="--reveal-delay:0.6s" aria-hidden="true">
      <svg class="stamp-spin w-full h-full" viewBox="0 0 100 100">
        <defs>
          <path id="stamp-circle" d="M 50,50 m -38,0 a 38,38 0 1,1 76,0 a 38,38 0 1,1 -76,0" fill="none" />
        </defs>
        <circle cx="50" cy="50" r="3.5" fill="var(--color-accent)" />
        <text fill="var(--color-ink)" font-size="9" letter-spacing="1.5" style="text-transform: uppercase;">
          <textPath href="#stamp-circle">{t('hero.stamp')}</textPath>
        </text>
      </svg>
    </div>

    <!-- Subtítulo + CTAs -->
    <div class="mt-auto pt-12 md:pt-16 flex flex-col md:flex-row md:items-end md:justify-between gap-8">
      <p class="reveal fadeInUp section-descr max-w-md" style="--reveal-delay:0.3s">
        {t('hero.subtitle')}
      </p>
      <div class="reveal fadeInUp flex flex-wrap items-center gap-x-6 gap-y-4 md:pb-1" style="--reveal-delay:0.4s">
        <AnimatedButton href={r.portfolio} variant="grad" size="large">{t('hero.cta.primary')}</AnimatedButton>
        <a href={r.services} class="btn-animate-y text-sm font-semibold text-ink">
          <span class="btn-animate-y-1">{t('hero.cta.secondary')} →</span>
          <span class="btn-animate-y-2" aria-hidden="true">{t('hero.cta.secondary')} →</span>
        </a>
      </div>
    </div>
  </div>

  <a href="#story" class="reveal fadeIn hidden md:flex absolute bottom-6 left-1/2 -translate-x-1/2 flex-col items-center gap-2 text-gray-1" style="--reveal-delay:0.7s">
    <span class="text-xs uppercase tracking-widest font-medium">{t('hero.scroll')}</span>
    <svg class="w-4 h-4 motion-safe:animate-bounce" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
    </svg>
  </a>
</section>

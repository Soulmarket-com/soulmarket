---
import Base from '../../layouts/Base.astro';
import Hero from '../../components/sections/Hero.astro';
import Marquee from '../../components/sections/Marquee.astro';
import Story from '../../components/sections/Story.astro';
import Services from '../../components/sections/Services.astro';
import FeaturedPortfolio from '../../components/sections/FeaturedPortfolio.astro';
import Team from '../../components/sections/Team.astro';
import LatestBlog from '../../components/sections/LatestBlog.astro';
import CtaBanner from '../../components/sections/CtaBanner.astro';
import { getBlogPosts, getPortfolioItems } from '../../lib/strapi';

const lang = 'en';

// El contenido de Strapi todavía no tiene i18n (solo ES) — ver soulmarket/CLAUDE.md.
const portfolioItems = (await getPortfolioItems()).filter((item) => item.data.featured);

const latestPosts = (await getBlogPosts()).slice(0, 3);
---

<Base
  title="Web Design, Photography & Digital Marketing"
  description="Soulmarket — Web design, photography, video and digital marketing for brands that want to stand out. Free no-commitment quote."
  lang="en"
>
  <Hero lang={lang} />
  <Marquee lang={lang} />
  <Story lang={lang} />
  <Services lang={lang} />
  <FeaturedPortfolio lang={lang} items={portfolioItems} />
  <Team lang={lang} />
  <LatestBlog lang={lang} posts={latestPosts} />
  <CtaBanner lang={lang} />
</Base>

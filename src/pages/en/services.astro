---
import Base from '../../layouts/Base.astro';
import ServicesDetail from '../../components/sections/ServicesDetail.astro';
import type { ServiceDetailItem } from '../../components/sections/ServicesDetail.astro';
import CtaBanner from '../../components/sections/CtaBanner.astro';
import { useTranslations } from '../../i18n/utils';

const lang = 'en';
const t = useTranslations(lang);

const services: ServiceDetailItem[] = [
  {
    id: 'web',
    art: 'web',
    title: t('service.web.title'),
    desc: t('service.web.desc'),
    bullets: [
      'Custom design, no templates',
      'Core Web Vitals optimized',
      'Technical SEO included',
      'Responsive and accessible',
      'Content management panel',
      'Server management & administration',
      'Database administration',
      'Domain and hosting owned by the client',
    ],
    price: 'From €800',
  },
  {
    id: 'uxui',
    art: 'uxui',
    title: t('service.uxui.title'),
    desc: t('service.uxui.desc'),
    bullets: [
      'Research and information architecture',
      'Wireframes and clickable prototypes',
      'Interface design and component systems',
      'Usability testing',
      'Dev-ready handoff',
    ],
    price: 'Custom quote',
  },
  {
    id: 'design',
    art: 'design',
    title: t('service.design.title'),
    desc: t('service.design.desc'),
    bullets: [
      'Logo and visual identity system',
      'Color palette and typography',
      'Brand guidelines',
      'Digital materials (social media, templates)',
      'Editable files included',
    ],
    price: 'From €400',
  },
  {
    id: 'media',
    art: 'media',
    title: t('service.media.title'),
    desc: t('service.media.desc'),
    bullets: [
      'Product or corporate photography',
      'Video for social media or web',
      'Professional editing and retouching',
      'Delivery in multiple formats',
      'Studio or on-location shoots',
    ],
    price: 'From €200',
  },
  {
    id: 'marketing',
    art: 'marketing',
    title: t('service.marketing.title'),
    desc: t('service.marketing.desc'),
    bullets: [
      'SEO audit and action plan',
      'Content strategy',
      'Social media management',
      'Google Ads / Meta Ads campaigns',
      'Web analytics (Google Analytics 4)',
      'Monthly results report',
    ],
    price: 'From €350/month',
  },
];
---

<Base
  title="Web design, photography and marketing services"
  description="Web design and development, graphic design, photography, video and digital marketing. Clear prices and a no-commitment quote."
  lang={lang}
>
  <header class="hero-columns relative overflow-hidden pt-28 md:pt-36 pb-8 md:pb-12">
    <div class="container-lg relative">
      <h1 class="reveal fadeInUp giant-heading text-ink mb-0">
        <em class="block">{t('services.giant.italic')}</em>
        <span class="block">{t('services.giant.main')}</span>
      </h1>
      <p class="reveal fadeInUp section-descr max-w-xl mt-7" style="--reveal-delay:0.1s">
        {t('services.page.intro')}
      </p>
    </div>
  </header>

  <ServicesDetail lang={lang} services={services} />

  <CtaBanner lang={lang} />
</Base>

---
import Base from '../layouts/Base.astro';
import ServicesDetail from '../components/sections/ServicesDetail.astro';
import type { ServiceDetailItem } from '../components/sections/ServicesDetail.astro';
import CtaBanner from '../components/sections/CtaBanner.astro';
import { useTranslations } from '../i18n/utils';

const lang = 'es';
const t = useTranslations(lang);

const services: ServiceDetailItem[] = [
  {
    id: 'web',
    art: 'web',
    title: t('service.web.title'),
    desc: t('service.web.desc'),
    bullets: [
      'Diseño a medida, no plantillas',
      'Optimizado para Core Web Vitals',
      'SEO técnico incluido',
      'Responsive y accesible',
      'Panel de gestión de contenido',
      'Gestión y administración de servidores',
      'Administración de bases de datos',
      'Dominio y hosting a cargo del cliente',
    ],
    price: 'Desde 800 €',
  },
  {
    id: 'uxui',
    art: 'uxui',
    title: t('service.uxui.title'),
    desc: t('service.uxui.desc'),
    bullets: [
      'Research y arquitectura de la información',
      'Wireframes y prototipos navegables',
      'Diseño de interfaz y sistema de componentes',
      'Tests de usabilidad',
      'Entrega lista para desarrollo',
    ],
    price: 'Presupuesto a medida',
  },
  {
    id: 'design',
    art: 'design',
    title: t('service.design.title'),
    desc: t('service.design.desc'),
    bullets: [
      'Logotipo y sistema de identidad visual',
      'Paleta de colores y tipografías',
      'Manual de marca',
      'Materiales digitales (redes, plantillas)',
      'Formatos editables incluidos',
    ],
    price: 'Desde 400 €',
  },
  {
    id: 'media',
    art: 'media',
    title: t('service.media.title'),
    desc: t('service.media.desc'),
    bullets: [
      'Fotografía de producto o corporativa',
      'Video para redes sociales o web',
      'Edición y retoque profesional',
      'Entrega en múltiples formatos',
      'Sesión en estudio o a domicilio',
    ],
    price: 'Desde 200 €',
  },
  {
    id: 'marketing',
    art: 'marketing',
    title: t('service.marketing.title'),
    desc: t('service.marketing.desc'),
    bullets: [
      'Auditoría SEO y plan de acción',
      'Estrategia de contenidos',
      'Gestión de redes sociales',
      'Campañas Google Ads / Meta Ads',
      'Analítica web (Google Analytics 4)',
      'Informe mensual de resultados',
    ],
    price: 'Desde 350 €/mes',
  },
];
---

<Base
  title="Servicios de diseño web, fotografía y marketing"
  description="Diseño y desarrollo web, diseño gráfico, fotografía, video y marketing digital. Precios claros y presupuesto sin compromiso."
  lang={lang}
>
  <header class="hero-columns relative overflow-hidden pt-28 md:pt-36 pb-8 md:pb-12">
    <div class="container-lg relative">
      <h1 class="reveal fadeInUp giant-heading text-ink mb-0">
        <em class="block">{t('services.giant.italic')}</em>
        <span class="block">{t('services.giant.main')}</span>
      </h1>
      <p class="reveal fadeInUp section-descr max-w-xl mt-7" style="--reveal-delay:0.1s">
        {t('services.page.intro')}
      </p>
    </div>
  </header>

  <ServicesDetail lang={lang} services={services} />

  <CtaBanner lang={lang} />
</Base>

---
import { useTranslations, routes } from '../i18n/utils';

interface Props {
  lang: 'es' | 'en';
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const r = routes[lang];
const year = new Date().getFullYear();
---

<footer class="bg-ink text-white/60">
  <div class="container-lg py-16">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-10">
      <!-- Brand column -->
      <div class="md:col-span-5">
        <a href={r.home} class="text-white font-bold text-xl tracking-tight">Soulmarket</a>
        <p class="mt-4 text-sm leading-relaxed max-w-xs">
          {t('footer.tagline')}
        </p>
        <!-- TODO: poner las URLs reales de LinkedIn/Instagram y quitar `hidden` -->
        <div class="hidden gap-3 mt-6">
          <!-- LinkedIn -->
          <a href="#" aria-label="LinkedIn" class="w-9 h-9 flex items-center justify-center rounded-full bg-white/8 hover:bg-white/15 transition-colors">
            <svg class="w-4 h-4 fill-current" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
          <!-- Instagram -->
          <a href="#" aria-label="Instagram" class="w-9 h-9 flex items-center justify-center rounded-full bg-white/8 hover:bg-white/15 transition-colors">
            <svg class="w-4 h-4 fill-current" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/></svg>
          </a>
        </div>
      </div>

      <!-- Services -->
      <div class="md:col-span-3">
        <h3 class="text-white text-xs font-semibold uppercase tracking-widest mb-5">{t('nav.services')}</h3>
        <ul class="space-y-3">
          <li><a href={`${r.services}#web`} class="text-sm hover:text-white transition-colors">{t('service.web.title')}</a></li>
          <li><a href={`${r.services}#design`} class="text-sm hover:text-white transition-colors">{t('service.design.title')}</a></li>
          <li><a href={`${r.services}#media`} class="text-sm hover:text-white transition-colors">{t('service.media.title')}</a></li>
          <li><a href={`${r.services}#marketing`} class="text-sm hover:text-white transition-colors">{t('service.marketing.title')}</a></li>
        </ul>
      </div>

      <!-- Pages -->
      <div class="md:col-span-2">
        <h3 class="text-white text-xs font-semibold uppercase tracking-widest mb-5">Soulmarket</h3>
        <ul class="space-y-3">
          <li><a href={r.portfolio} class="text-sm hover:text-white transition-colors">{t('nav.portfolio')}</a></li>
          <li><a href={r.blog} class="text-sm hover:text-white transition-colors">{t('nav.blog')}</a></li>
          <li><a href={r.about} class="text-sm hover:text-white transition-colors">{t('nav.about')}</a></li>
          <li><a href={r.contact} class="text-sm hover:text-white transition-colors">{t('nav.contact')}</a></li>
        </ul>
      </div>

      <!-- Contact -->
      <div class="md:col-span-2">
        <h3 class="text-white text-xs font-semibold uppercase tracking-widest mb-5">{t('nav.contact')}</h3>
        <ul class="space-y-3">
          <li>
            <a href="mailto:hola@soulmarket.com" class="text-sm hover:text-white transition-colors break-all">
              hola@soulmarket.com
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div class="mt-12 pt-8 border-t border-white/10 flex flex-col sm:flex-row justify-between items-center gap-4">
      <p class="text-xs text-white/30">
        &copy; {year} Soulmarket. {t('footer.rights')}
      </p>
      <a href={r.privacy} class="text-xs text-white/30 hover:text-white transition-colors">
        {t('footer.privacy')}
      </a>
    </div>
  </div>
</footer>

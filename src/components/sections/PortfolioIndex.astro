---
import { useTranslations, routes, withBase } from '../../i18n/utils';
import type { CollectionEntry } from 'astro:content';

interface Props {
  lang: 'es' | 'en';
  items: CollectionEntry<'portfolio'>[];
}

const { lang, items } = Astro.props;
const t = useTranslations(lang);
const r = routes[lang];

const categoryLabels: Record<string, string> = {
  web: t('portfolio.filter.web'),
  design: t('portfolio.filter.design'),
  'photo-video': t('portfolio.filter.media'),
  marketing: t('portfolio.filter.marketing'),
};

const filters = [
  { id: 'all', label: t('portfolio.filter.all'), count: items.length },
  ...Object.entries(categoryLabels).map(([id, label]) => ({
    id,
    label,
    count: items.filter((i) => i.data.category === id).length,
  })),
].filter((f) => f.count > 0);
---

<header class="hero-columns relative overflow-hidden pt-28 md:pt-36 pb-6 md:pb-10">
  <div class="container-lg relative">
    <h1 class="reveal fadeInUp giant-heading text-ink mb-0">
      <em class="block">{t('portfolio.page.italic')}</em>
      <span class="block">{t('portfolio.page.main')}</span>
    </h1>
  </div>
</header>

<section class="pb-20 md:pb-28">
  <div class="container-lg">
    <div class="reveal fadeInUp flex flex-wrap items-baseline gap-x-8 gap-y-3 py-8 mb-10 border-b border-border" role="group" aria-label={t('portfolio.title')}>
      {filters.map(({ id, label, count }) => (
        <button
          type="button"
          class="filter-btn"
          data-filter={id}
          aria-pressed={id === 'all' ? 'true' : 'false'}
        >
          {label}
          <sup class="filter-count">{count}</sup>
        </button>
      ))}
    </div>

    {items.length === 0 ? (
      <p class="text-center text-muted py-20">{t('portfolio.empty')}</p>
    ) : (
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-8 gap-y-14" id="portfolio-grid">
        {items.map((item) => (
          <a
            href={`${r.portfolio}/${item.id}`}
            data-category={item.data.category}
            class="portfolio-item group block"
          >
            <div class="aspect-[16/10] bg-surface overflow-hidden rounded-xl border border-border">
              <img
                src={withBase(item.data.image)}
                alt={item.data.imageAlt || item.data.title}
                width="800"
                height="500"
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                loading="lazy"
              />
            </div>
            <div class="pt-5 flex items-start justify-between gap-4">
              <div>
                <h2 class="portfolio-card-title text-ink mb-0 group-hover:text-accent transition-colors">{item.data.title}</h2>
                <p class="font-display italic text-muted mt-1.5">{item.data.description}</p>
              </div>
              <span class="shrink-0 text-xs font-medium text-accent bg-accent/8 px-2.5 py-1 rounded-full mt-1.5">
                {categoryLabels[item.data.category] ?? item.data.category}
              </span>
            </div>
          </a>
        ))}
      </div>
    )}
  </div>
</section>

<style>
  .filter-btn {
    position: relative;
    padding-bottom: 4px;
    font-size: 13px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-muted);
    cursor: pointer;
    transition: color 0.25s var(--ease-default);
  }
  .filter-btn::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 2px;
    background: var(--color-accent);
    transform: scaleX(0);
    transform-origin: left center;
    transition: transform 0.3s var(--ease-out-short);
  }
  .filter-btn:hover { color: var(--color-ink); }
  .filter-btn[aria-pressed="true"] {
    color: var(--color-ink);
  }
  .filter-btn[aria-pressed="true"]::after { transform: scaleX(1); }
  .filter-count {
    font-family: var(--font-family-display);
    font-style: italic;
    font-weight: 460;
    text-transform: none;
    letter-spacing: 0;
    color: var(--color-accent);
    margin-left: 0.35em;
  }

  .portfolio-card-title {
    font-optical-sizing: auto;
    font-weight: 800;
    font-size: clamp(1.4rem, 1.1rem + 1.2vw, 2rem);
    line-height: 1;
    letter-spacing: -0.01em;
    text-transform: uppercase;
  }

  .portfolio-item.is-hidden { display: none; }
  .portfolio-item.card-in {
    animation: card-in 0.45s var(--ease-out-short) both;
  }
  @keyframes card-in {
    from { opacity: 0; transform: translateY(16px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @media (prefers-reduced-motion: reduce) {
    .portfolio-item.card-in { animation: none; }
  }
</style>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const cards = document.querySelectorAll<HTMLElement>('.portfolio-item');

  buttons.forEach((btn) => {
    btn.addEventListener('click', () => {
      const filter = btn.dataset.filter;
      buttons.forEach((b) => b.setAttribute('aria-pressed', String(b === btn)));

      cards.forEach((card) => {
        const show = filter === 'all' || card.dataset.category === filter;
        card.classList.toggle('is-hidden', !show);
        card.classList.remove('card-in');
        if (show) {
          // Reinicia la animación de entrada en cada filtrado
          void card.offsetWidth;
          card.classList.add('card-in');
        }
      });
    });
  });
</script>

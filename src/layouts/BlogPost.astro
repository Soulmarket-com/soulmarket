---
import Base from './Base.astro';
import CtaBanner from '../components/sections/CtaBanner.astro';
import { getLangFromUrl, useTranslations, routes, withBase } from '../i18n/utils';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  image?: string;
  imageAlt?: string;
  tags?: string[];
  lang?: 'es' | 'en';
}

const { title, description, pubDate, updatedDate, image, imageAlt, tags = [], lang } = Astro.props;
const resolvedLang = lang ?? getLangFromUrl(Astro.url);
const t = useTranslations(resolvedLang);
const r = routes[resolvedLang];

function formatDate(date: Date) {
  return new Intl.DateTimeFormat(resolvedLang === 'es' ? 'es-ES' : 'en-US', {
    year: 'numeric', month: 'long', day: 'numeric',
  }).format(date);
}
---

<Base title={title} description={description} image={image} lang={resolvedLang} type="article">
  <article>
    <header class="hero-columns relative overflow-hidden pt-28 md:pt-32 pb-10 md:pb-14">
      <div class="container-md relative">
        <a href={r.blog} class="btn-animate-y inline-block text-sm font-semibold text-muted hover:text-ink transition-colors mb-10">
          <span class="btn-animate-y-1">← {t('blog.back')}</span>
          <span class="btn-animate-y-2" aria-hidden="true">← {t('blog.back')}</span>
        </a>

        <div class="flex flex-wrap items-center gap-x-4 gap-y-2 mb-6">
          <time class="text-xs font-semibold uppercase tracking-[0.16em] text-muted" datetime={pubDate.toISOString()}>
            {formatDate(pubDate)}
          </time>
          {updatedDate && (
            <span class="text-xs font-semibold uppercase tracking-[0.16em] text-muted">
              · {t('blog.updated')}: {formatDate(updatedDate)}
            </span>
          )}
          {tags.map((tag) => (
            <span class="text-xs font-medium text-accent bg-accent/8 px-2.5 py-1 rounded-full">{tag}</span>
          ))}
        </div>

        <h1 class="post-title text-ink mb-0">{title}</h1>
        <p class="font-display italic text-muted text-lg md:text-xl mt-5 max-w-2xl">{description}</p>
      </div>
    </header>

    {image && (
      <div class="container-md mb-12 md:mb-16">
        <img
          src={withBase(image)}
          alt={imageAlt || title}
          width="1024"
          height="576"
          class="w-full aspect-video object-cover rounded-xl border border-border"
        />
      </div>
    )}

    <div class="container-sm pb-16 md:pb-20 prose-content">
      <slot />
    </div>
  </article>

  <CtaBanner lang={resolvedLang} />
</Base>

<style>
  /* Titular de artículo: serif grande en caja normal (los títulos largos
     de blog no funcionan en caja alta) */
  .post-title {
    font-family: var(--font-family-display);
    font-optical-sizing: auto;
    font-weight: 640;
    font-size: clamp(2rem, 1.3rem + 3vw, 3.5rem);
    line-height: 1.08;
    letter-spacing: -0.02em;
    text-wrap: balance;
  }
</style>

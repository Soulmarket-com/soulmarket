---
import Base from '../../layouts/Base.astro';
import CtaBanner from '../../components/sections/CtaBanner.astro';
import { useTranslations } from '../../i18n/utils';

const lang = 'en';
const t = useTranslations(lang);
---

<Base
  title="About me — Freelance web designer and photographer"
  description="I'm José Miguel, a freelance web designer and photographer. Learn about me and how I can help with your digital project."
  lang="en"
>
  <header class="bg-ink text-white pt-28 pb-16">
    <div class="container-lg">
      <span class="text-accent-light text-xs font-semibold uppercase tracking-widest">{t('about.eyebrow')}</span>
      <h1 class="text-4xl sm:text-5xl md:text-6xl font-extrabold mt-3 tracking-tight">{t('about.title')}</h1>
    </div>
  </header>

  <section class="section-gap">
    <div class="container-md">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-16 items-start">
        <div class="aspect-[3/4] bg-surface rounded-2xl flex items-center justify-center text-7xl sticky top-24">
          🧑‍💻
        </div>
        <div>
          <h2 class="text-2xl font-extrabold text-ink mb-6">Hi, I'm José Miguel</h2>
          <div class="prose-content space-y-4 text-muted text-base leading-relaxed">
            <p>
              I'm a creative professional with experience in web design, photography and digital marketing.
              My mission is to help freelancers and small businesses build a digital presence that
              reflects their essence and helps them grow.
            </p>
            <p>
              I started in graphic design and gradually moved into web development and professional photography.
              Today I offer a comprehensive service covering everything from brand identity to digital strategy.
            </p>
            <p>
              What sets me apart is the combination of artistic sensibility and technical knowledge:
              I build websites that are not only beautiful, but also fast, functional and rank well.
            </p>
          </div>
          <div class="mt-10">
            <h3 class="text-sm font-semibold uppercase tracking-widest text-muted mb-5">Skills</h3>
            <div class="flex flex-wrap gap-2">
              {['Astro.js', 'React', 'Tailwind CSS', 'WordPress', 'Figma', 'Adobe Photoshop', 'Lightroom', 'Final Cut Pro', 'SEO', 'Google Ads', 'Meta Ads'].map(skill => (
                <span class="text-sm bg-surface border border-border text-ink px-3 py-1.5 rounded-lg font-medium">{skill}</span>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <CtaBanner lang={lang} />
</Base>

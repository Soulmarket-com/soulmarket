---
import Base from '../../layouts/Base.astro';
import { useTranslations } from '../../i18n/utils';

const lang = 'en';
const t = useTranslations(lang);
---

<Base
  title="Contact — Tell me about your project"
  description="Got a web design, photography or marketing project? Tell me about it and I'll prepare a proposal within 24 hours."
  lang="en"
>
  <header class="bg-ink text-white pt-28 pb-16">
    <div class="container-lg">
      <span class="text-accent-light text-xs font-semibold uppercase tracking-widest">{t('contact.eyebrow')}</span>
      <h1 class="text-4xl sm:text-5xl md:text-6xl font-extrabold mt-3 tracking-tight">{t('contact.title')}</h1>
      <p class="mt-5 text-white/55 text-lg max-w-xl">{t('contact.subtitle')}</p>
    </div>
  </header>

  <section class="section-gap">
    <div class="container-md">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-16">
        <div class="lg:col-span-3">
          <form id="contact-form" class="space-y-5">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <div>
                <label for="name" class="block text-sm font-medium text-ink mb-1.5">{t('contact.name')}</label>
                <input type="text" id="name" name="name" required
                  class="w-full px-4 py-3 rounded-xl border border-border bg-surface text-ink text-sm focus:outline-none focus:ring-2 focus:ring-accent focus:border-transparent transition-all" />
              </div>
              <div>
                <label for="email" class="block text-sm font-medium text-ink mb-1.5">{t('contact.email')}</label>
                <input type="email" id="email" name="email" required
                  class="w-full px-4 py-3 rounded-xl border border-border bg-surface text-ink text-sm focus:outline-none focus:ring-2 focus:ring-accent focus:border-transparent transition-all" />
              </div>
            </div>
            <div>
              <label for="subject" class="block text-sm font-medium text-ink mb-1.5">{t('contact.subject')}</label>
              <input type="text" id="subject" name="subject" required
                class="w-full px-4 py-3 rounded-xl border border-border bg-surface text-ink text-sm focus:outline-none focus:ring-2 focus:ring-accent focus:border-transparent transition-all" />
            </div>
            <div>
              <label for="message" class="block text-sm font-medium text-ink mb-1.5">{t('contact.message')}</label>
              <textarea id="message" name="message" rows="6" required
                class="w-full px-4 py-3 rounded-xl border border-border bg-surface text-ink text-sm focus:outline-none focus:ring-2 focus:ring-accent focus:border-transparent transition-all resize-none"></textarea>
            </div>
            <div id="form-feedback" class="hidden text-sm p-4 rounded-xl" aria-live="polite"></div>
            <button type="submit" id="submit-btn"
              class="w-full bg-accent hover:bg-accent-dark text-white font-semibold py-3.5 rounded-xl transition-colors disabled:opacity-60 disabled:cursor-not-allowed">
              {t('contact.send')}
            </button>
          </form>
        </div>
        <div class="lg:col-span-2 space-y-8">
          <div>
            <h3 class="text-sm font-semibold uppercase tracking-widest text-muted mb-4">Email</h3>
            <a href="mailto:hola@soulmarket.com" class="text-ink font-medium hover:text-accent transition-colors">
              hola@soulmarket.com
            </a>
          </div>
          <div>
            <h3 class="text-sm font-semibold uppercase tracking-widest text-muted mb-4">Response time</h3>
            <p class="text-ink text-sm">I usually reply within 24 hours on business days.</p>
          </div>
        </div>
      </div>
    </div>
  </section>
</Base>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const feedback = document.getElementById('form-feedback')!;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    submitBtn.disabled = true;
    submitBtn.textContent = 'Sending...';
    const data = new FormData(form);
    try {
      const res = await fetch('https://formspree.io/f/YOUR_FORM_ID', {
        method: 'POST', body: data, headers: { Accept: 'application/json' },
      });
      if (res.ok) {
        feedback.className = 'text-sm p-4 rounded-xl bg-green-50 text-green-800 border border-green-200';
        feedback.textContent = 'Message sent. I will reply within 24 h.';
        form.reset();
      } else throw new Error();
    } catch {
      feedback.className = 'text-sm p-4 rounded-xl bg-red-50 text-red-800 border border-red-200';
      feedback.textContent = 'Something went wrong. Email me at hola@soulmarket.com';
    } finally {
      feedback.classList.remove('hidden');
      submitBtn.disabled = false;
      submitBtn.textContent = 'Send message';
    }
  });
</script>

---
import Base from '../../../layouts/Base.astro';
import PortfolioIndex from '../../../components/sections/PortfolioIndex.astro';
import CtaBanner from '../../../components/sections/CtaBanner.astro';
import { getPortfolioItems } from '../../../lib/strapi';

const lang = 'en';

// El contenido de Strapi todavía no tiene i18n (solo ES) — ver soulmarket/CLAUDE.md.
const items = await getPortfolioItems();
---

<Base
  title="Web design and digital projects portfolio"
  description="Web design, branding, photography and digital marketing projects. Real work with real results."
  lang={lang}
>
  <PortfolioIndex lang={lang} items={items} />
  <CtaBanner lang={lang} />
</Base>

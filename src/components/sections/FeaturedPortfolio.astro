---
import { useTranslations, routes, withBase } from '../../i18n/utils';
import type { PortfolioEntry } from '../../lib/strapi';

interface Props {
  lang: 'es' | 'en';
  items: PortfolioEntry[];
}

const { lang, items } = Astro.props;
const t = useTranslations(lang);
const r = routes[lang];

const categoryLabels: Record<string, string> = {
  web: t('portfolio.filter.web'),
  design: t('portfolio.filter.design'),
  'photo-video': t('portfolio.filter.media'),
  marketing: t('portfolio.filter.marketing'),
};
---

<section class="section-gap-lg" id="portfolio-home">
  <div class="container-lg">
    <div class="relative flex flex-wrap items-end justify-between gap-6 mb-14 md:mb-20">
      <h2 class="reveal fadeInUp giant-heading text-ink mb-0">
        <em class="block">{t('portfolio.giant.italic')}</em>
        <span class="block">{t('portfolio.giant.main')}</span>
      </h2>

      <!-- Sello giratorio, enlace a todo el portfolio; en móvil se superpone
           arriba a la derecha (el hueco que deja la itálica corta) -->
      <a
        href={r.portfolio}
        class="reveal fadeIn portfolio-stamp group absolute -top-6 right-0 w-20 h-20 sm:relative sm:top-auto sm:right-auto sm:w-28 sm:h-28 lg:w-36 lg:h-36 shrink-0"
        style="--reveal-delay:0.3s"
        aria-label={t('portfolio.cta')}
      >
        <svg class="stamp-spin w-full h-full" viewBox="0 0 100 100" aria-hidden="true">
          <defs>
            <path id="portfolio-stamp-circle" d="M 50,50 m -40,0 a 40,40 0 1,1 80,0 a 40,40 0 1,1 -80,0" fill="none" />
          </defs>
          <text fill="var(--color-ink)" font-size="8.5" letter-spacing="1.4" style="text-transform: uppercase;">
            <textPath href="#portfolio-stamp-circle">{t('portfolio.stamp')}</textPath>
          </text>
        </svg>
        <span class="absolute inset-0 flex items-center justify-center text-2xl text-accent transition-transform duration-300 group-hover:translate-x-1" aria-hidden="true">→</span>
      </a>
    </div>

    {items.length === 0 ? (
      <p class="text-center text-muted py-16">{t('portfolio.empty')}</p>
    ) : (
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-8 gap-y-14">
        {items.slice(0, 4).map((item, i) => (
          <a
            href={`${r.portfolio}/${item.id}`}
            class="reveal fadeInUp group block"
            style={`--reveal-delay:${(i % 2) * 0.12}s`}
          >
            <div class="aspect-[16/10] bg-surface overflow-hidden rounded-xl border border-border">
              <img
                src={withBase(item.data.image)}
                alt={item.data.imageAlt || item.data.title}
                width="800"
                height="500"
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                loading="lazy"
              />
            </div>
            <div class="pt-5 flex items-start justify-between gap-4">
              <div>
                <h3 class="portfolio-card-title text-ink mb-0 group-hover:text-accent transition-colors">{item.data.title}</h3>
                <p class="font-display italic text-muted mt-1.5">{item.data.description}</p>
              </div>
              <span class="shrink-0 text-xs font-medium text-accent bg-accent/8 px-2.5 py-1 rounded-full mt-1.5">
                {categoryLabels[item.data.category] ?? item.data.category}
              </span>
            </div>
          </a>
        ))}
      </div>
    )}

    <div class="reveal fadeInUp sm:hidden text-center mt-12">
      <a href={r.portfolio} class="btn-animate-y inline-block text-sm font-semibold text-ink underline underline-offset-4">
        <span class="btn-animate-y-1">{t('portfolio.cta')} →</span>
        <span class="btn-animate-y-2" aria-hidden="true">{t('portfolio.cta')} →</span>
      </a>
    </div>
  </div>
</section>

<style>
  .portfolio-card-title {
    font-optical-sizing: auto;
    font-weight: 800;
    font-size: clamp(1.4rem, 1.1rem + 1.2vw, 2rem);
    line-height: 1;
    letter-spacing: -0.01em;
    text-transform: uppercase;
  }
</style>

---
import Base from './Base.astro';
import { getLangFromUrl, routes } from '../i18n/utils';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  image?: string;
  imageAlt?: string;
  tags?: string[];
  lang?: 'es' | 'en';
}

const { title, description, pubDate, updatedDate, image, imageAlt, tags = [], lang } = Astro.props;
const resolvedLang = lang ?? getLangFromUrl(Astro.url);
const r = routes[resolvedLang];

const formattedDate = new Intl.DateTimeFormat(resolvedLang === 'es' ? 'es-ES' : 'en-US', {
  year: 'numeric', month: 'long', day: 'numeric',
}).format(pubDate);

const formattedUpdated = updatedDate
  ? new Intl.DateTimeFormat(resolvedLang === 'es' ? 'es-ES' : 'en-US', {
      year: 'numeric', month: 'long', day: 'numeric',
    }).format(updatedDate)
  : null;
---

<Base title={title} description={description} image={image} lang={resolvedLang} type="article">
  <article>
    <!-- Hero -->
    <header class="bg-ink text-white pt-28 pb-16">
      <div class="container-sm">
        <a href={r.blog} class="inline-flex items-center gap-1.5 text-white/50 hover:text-white text-sm mb-8 transition-colors">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
          {resolvedLang === 'es' ? 'Volver al blog' : 'Back to blog'}
        </a>
        {tags.length > 0 && (
          <div class="flex flex-wrap gap-2 mb-6">
            {tags.map(tag => (
              <span class="text-xs font-medium bg-white/10 text-white/70 px-3 py-1 rounded-full">{tag}</span>
            ))}
          </div>
        )}
        <h1 class="text-3xl sm:text-4xl md:text-5xl font-extrabold leading-tight tracking-tight mb-6">
          {title}
        </h1>
        <p class="text-white/60 text-lg mb-8">{description}</p>
        <div class="flex items-center gap-2 text-white/40 text-sm">
          <time datetime={pubDate.toISOString()}>{formattedDate}</time>
          {formattedUpdated && (
            <>
              <span>·</span>
              <span>{resolvedLang === 'es' ? 'Actualizado' : 'Updated'}: {formattedUpdated}</span>
            </>
          )}
        </div>
      </div>
    </header>

    {image && (
      <div class="container-md -mt-8 mb-12">
        <img
          src={image}
          alt={imageAlt || title}
          class="w-full aspect-video object-cover rounded-2xl shadow-xl"
        />
      </div>
    )}

    <!-- Content -->
    <div class="container-sm py-12 prose-content">
      <slot />
    </div>
  </article>
</Base>

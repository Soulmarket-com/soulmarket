---
import { useTranslations, routes, translatePath } from '../i18n/utils';
import AnimatedButton from './ui/AnimatedButton.astro';

interface Props {
  lang: 'es' | 'en';
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const r = routes[lang];
const otherLang = lang === 'es' ? 'en' : 'es';
// A la página equivalente si existe; a la home del otro idioma si no
const otherLangUrl = translatePath(Astro.url.pathname, otherLang) ?? routes[otherLang].home;

const navItems = [
  { label: t('nav.home'), href: r.home },
  { label: t('nav.services'), href: r.services },
  { label: t('nav.portfolio'), href: r.portfolio },
  { label: t('nav.blog'), href: r.blog },
  { label: t('nav.about'), href: r.about },
];

const path = Astro.url.pathname;
const year = new Date().getFullYear();

function isActive(href: string) {
  if (href === '/' || href === '/en/') return path === href;
  return path.startsWith(href);
}
---

<header id="site-header" class="site-header fixed top-0 left-0 right-0 z-50">
  <nav class="site-header-nav relative flex items-center justify-between">
    <a href={r.home} class="site-logo font-display font-semibold text-xl tracking-tight transition-colors">
      soulmarket<span class="text-accent">.</span>
    </a>

    <p class="site-tagline hidden lg:block absolute left-1/2 -translate-x-1/2 text-[11px] uppercase tracking-[0.24em] font-medium pointer-events-none" aria-hidden="true">
      {t('nav.tagline')}
    </p>

    <div class="flex items-center gap-3 md:gap-4">
      <a
        href={otherLangUrl}
        class="site-lang hidden sm:inline text-xs uppercase tracking-widest font-semibold transition-colors"
        hreflang={otherLang}
      >
        {otherLang}
      </a>
      <AnimatedButton href={r.contact} variant="grad" size="small" class="hidden sm:inline-flex">{t('nav.cta')}</AnimatedButton>
      <button
        id="menu-btn"
        class="menu-toggle -mr-2"
        aria-label={t('nav.menuLabel')}
        aria-expanded="false"
        aria-controls="site-menu"
      >
        <span class="menu-toggle-bar" aria-hidden="true"></span>
        <span class="menu-toggle-bar" aria-hidden="true"></span>
      </button>
    </div>
  </nav>
</header>

<!-- Menú a pantalla completa (referencia epic.net): cortina oscura, nav serif
     a la izquierda, mega-CTA a la derecha y barra inferior de contacto. -->
<div id="site-menu" class="menu-overlay light-content" role="dialog" aria-modal="true" aria-label={t('nav.menuLabel')}>
  <div class="container-lg relative flex-1 flex flex-col w-full min-h-full">
    <div class="flex-1 grid lg:grid-cols-[1.1fr_auto_1fr] gap-10 lg:gap-16 items-center pt-28 pb-8 lg:pb-16">
      <nav>
        <ul class="flex flex-col gap-1 md:gap-2">
          {navItems.map(({ label, href }, i) => (
            <li class="menu-item" style={`--menu-i:${i}`}>
              <a
                href={href}
                class:list={['menu-link', isActive(href) && 'is-active']}
                aria-current={isActive(href) ? 'page' : undefined}
              >
                <span class="menu-index" aria-hidden="true">0{i + 1}</span>
                {label}
              </a>
            </li>
          ))}
        </ul>
      </nav>

      <div class="menu-divider hidden lg:block self-stretch" aria-hidden="true"></div>

      <a href={r.contact} class="menu-start menu-item block text-center" style={`--menu-i:${navItems.length}`}>
        <span class="menu-start-small">{t('menu.start.pre')}</span>
        <span class="menu-start-big">
          <em>{t('menu.start.italic')}</em>
          {t('menu.start.big')}
        </span>
        <span class="menu-start-small">{t('menu.start.post')}</span>
      </a>
    </div>

    <div class="menu-footer menu-item flex flex-wrap items-center justify-between gap-x-8 gap-y-3 py-6" style={`--menu-i:${navItems.length + 1}`}>
      <a href="mailto:hola@soulmarket.com" class="font-display italic text-lg md:text-xl text-paper hover:text-accent-light transition-colors">
        hola@soulmarket.com
      </a>
      <div class="flex items-center gap-6">
        <a href={otherLangUrl} hreflang={otherLang} class="text-xs uppercase tracking-widest font-semibold text-paper/50 hover:text-paper transition-colors">
          {otherLang}
        </a>
        <span class="text-xs text-paper/35">© {year} Soulmarket</span>
      </div>
    </div>
  </div>
</div>

<script>
  const header = document.getElementById('site-header');
  const btn = document.getElementById('menu-btn');
  const overlay = document.getElementById('site-menu');

  const focusables = () =>
    overlay ? [...overlay.querySelectorAll<HTMLElement>('a[href], button:not([disabled])')] : [];

  function setOpen(open: boolean) {
    overlay?.classList.toggle('is-open', open);
    header?.classList.toggle('menu-open', open);
    document.documentElement.classList.toggle('menu-locked', open);
    btn?.setAttribute('aria-expanded', String(open));
    if (open) focusables()[0]?.focus({ preventScroll: true });
  }

  btn?.addEventListener('click', () => {
    setOpen(!overlay?.classList.contains('is-open'));
  });

  document.addEventListener('keydown', (e) => {
    if (!overlay?.classList.contains('is-open')) return;

    if (e.key === 'Escape') {
      setOpen(false);
      btn?.focus();
      return;
    }

    // Trampa de foco: Tab circula entre el botón de cierre y el diálogo
    if (e.key === 'Tab') {
      const items = [btn, ...focusables()].filter(Boolean) as HTMLElement[];
      if (items.length === 0) return;
      const first = items[0];
      const last = items[items.length - 1];
      const active = document.activeElement as HTMLElement | null;
      if (e.shiftKey && active === first) {
        e.preventDefault();
        last.focus();
      } else if (!e.shiftKey && active === last) {
        e.preventDefault();
        first.focus();
      } else if (active && !items.includes(active)) {
        e.preventDefault();
        first.focus();
      }
    }
  });

  // Header expansivo: alineado a la retícula arriba, a los bordes del viewport al hacer scroll
  let ticking = false;
  const onScroll = () => {
    if (ticking) return;
    ticking = true;
    requestAnimationFrame(() => {
      header?.classList.toggle('is-scrolled', window.scrollY > 24);
      ticking = false;
    });
  };
  onScroll();
  window.addEventListener('scroll', onScroll, { passive: true });
</script>

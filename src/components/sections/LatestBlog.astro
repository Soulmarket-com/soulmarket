---
import { useTranslations, routes } from '../../i18n/utils';
import type { CollectionEntry } from 'astro:content';

interface Props {
  lang: 'es' | 'en';
  posts: CollectionEntry<'blog'>[];
}

const { lang, posts } = Astro.props;
const t = useTranslations(lang);
const r = routes[lang];

function formatDate(date: Date) {
  return new Intl.DateTimeFormat(lang === 'es' ? 'es-ES' : 'en-US', {
    year: 'numeric', month: 'short', day: 'numeric',
  }).format(date);
}
---

<section class="section-gap bg-ink text-white">
  <div class="container-lg">
    <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-4 mb-14">
      <div>
        <span class="text-accent-light text-xs font-semibold uppercase tracking-widest">{t('blog.eyebrow')}</span>
        <h2 class="text-3xl sm:text-4xl md:text-5xl font-extrabold mt-3 tracking-tight">
          {t('blog.title')}
        </h2>
      </div>
      <a href={r.blog} class="text-sm font-semibold text-white/40 hover:text-white transition-colors whitespace-nowrap">
        {t('blog.cta')} →
      </a>
    </div>

    {posts.length === 0 ? (
      <p class="text-center text-white/40 py-16">{t('blog.empty')}</p>
    ) : (
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {posts.map((post, i) => (
          <a
            href={`${r.blog}/${post.id}`}
            class:list={[
              'group block rounded-2xl p-6 border transition-all duration-300 hover:border-white/20',
              i === 0
                ? 'md:row-span-1 bg-white/5 border-white/10'
                : 'bg-white/3 border-white/8',
            ]}
          >
            {post.data.image && (
              <div class="aspect-video overflow-hidden rounded-xl mb-5">
                <img
                  src={post.data.image}
                  alt={post.data.imageAlt || post.data.title}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                  loading="lazy"
                />
              </div>
            )}
            {post.data.tags.length > 0 && (
              <div class="flex flex-wrap gap-1.5 mb-3">
                {post.data.tags.slice(0, 2).map(tag => (
                  <span class="text-xs text-white/40 bg-white/8 px-2.5 py-0.5 rounded-full">{tag}</span>
                ))}
              </div>
            )}
            <h3 class="font-bold text-white text-base leading-snug mb-2 group-hover:text-accent-light transition-colors">
              {post.data.title}
            </h3>
            <p class="text-sm text-white/45 leading-relaxed line-clamp-2 mb-4">{post.data.description}</p>
            <div class="flex items-center justify-between">
              <time class="text-xs text-white/30" datetime={post.data.pubDate.toISOString()}>
                {formatDate(post.data.pubDate)}
              </time>
              <span class="text-xs font-semibold text-accent-light group-hover:translate-x-0.5 transition-transform inline-block">
                {t('blog.readMore')} →
              </span>
            </div>
          </a>
        ))}
      </div>
    )}
  </div>
</section>

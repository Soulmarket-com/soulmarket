---
import Base from '../../layouts/Base.astro';
import PortfolioIndex from '../../components/sections/PortfolioIndex.astro';
import CtaBanner from '../../components/sections/CtaBanner.astro';
import { getCollection } from 'astro:content';

const lang = 'es';

const allItems = await getCollection('portfolio', ({ data }) => data.lang === lang);
const items = allItems.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Base
  title="Portfolio de diseño web y proyectos digitales"
  description="Proyectos de diseño web, branding, fotografía y marketing digital. Trabajos reales con resultados reales."
  lang={lang}
>
  <PortfolioIndex lang={lang} items={items} />
  <CtaBanner lang={lang} />
</Base>

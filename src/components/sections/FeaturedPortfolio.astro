---
import { useTranslations, routes } from '../../i18n/utils';
import type { CollectionEntry } from 'astro:content';

interface Props {
  lang: 'es' | 'en';
  items: CollectionEntry<'portfolio'>[];
}

const { lang, items } = Astro.props;
const t = useTranslations(lang);
const r = routes[lang];

const categoryLabels: Record<string, string> = {
  web: t('portfolio.filter.web'),
  design: t('portfolio.filter.design'),
  'photo-video': t('portfolio.filter.media'),
  marketing: t('portfolio.filter.marketing'),
};
---

<section class="section-gap">
  <div class="container-lg">
    <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-4 mb-14">
      <div>
        <span class="text-accent text-xs font-semibold uppercase tracking-widest">{t('portfolio.eyebrow')}</span>
        <h2 class="text-3xl sm:text-4xl md:text-5xl font-extrabold text-ink mt-3 tracking-tight">
          {t('portfolio.title')}
        </h2>
      </div>
      <a href={r.portfolio} class="text-sm font-semibold text-muted hover:text-ink transition-colors whitespace-nowrap">
        {t('portfolio.cta')} →
      </a>
    </div>

    {items.length === 0 ? (
      <p class="text-center text-muted py-16">{t('portfolio.empty')}</p>
    ) : (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {items.map((item) => (
          <a
            href={`${r.portfolio}/${item.id}`}
            class="group block rounded-2xl overflow-hidden border border-border hover:border-transparent hover:shadow-xl transition-all duration-300"
          >
            <div class="aspect-[4/3] bg-surface overflow-hidden">
              <img
                src={item.data.image}
                alt={item.data.imageAlt || item.data.title}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                loading="lazy"
              />
            </div>
            <div class="p-5">
              <div class="flex items-center justify-between mb-2">
                <span class="text-xs font-medium text-accent bg-accent/8 px-2.5 py-1 rounded-full">
                  {categoryLabels[item.data.category] ?? item.data.category}
                </span>
                {item.data.client && (
                  <span class="text-xs text-muted">{item.data.client}</span>
                )}
              </div>
              <h3 class="font-bold text-ink text-base leading-snug">{item.data.title}</h3>
              <p class="text-sm text-muted mt-1.5 line-clamp-2">{item.data.description}</p>
              <span class="mt-4 inline-flex items-center gap-1 text-xs font-semibold text-accent group-hover:gap-2 transition-all">
                {t('portfolio.viewProject')}
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                </svg>
              </span>
            </div>
          </a>
        ))}
      </div>
    )}
  </div>
</section>

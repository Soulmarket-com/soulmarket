---
import { useTranslations, routes } from '../i18n/utils';

interface Props {
  lang: 'es' | 'en';
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const r = routes[lang];
const otherLang = lang === 'es' ? 'en' : 'es';
const otherLangUrl = lang === 'es' ? '/en/' : '/';

const navItems = [
  { label: t('nav.services'), href: r.services },
  { label: t('nav.portfolio'), href: r.portfolio },
  { label: t('nav.blog'), href: r.blog },
  { label: t('nav.about'), href: r.about },
];

const path = Astro.url.pathname;

function isActive(href: string) {
  if (href === '/' || href === '/en/') return path === href;
  return path.startsWith(href);
}
---

<header class="fixed top-0 left-0 right-0 z-50 bg-ink/95 backdrop-blur-sm border-b border-white/10">
  <nav class="container-lg flex items-center justify-between h-16">
    <a href={r.home} class="text-white font-bold text-xl tracking-tight hover:text-accent-light transition-colors">
      Soulmarket
    </a>

    <ul class="hidden md:flex items-center gap-0.5">
      {navItems.map(({ label, href }) => (
        <li>
          <a
            href={href}
            class:list={[
              'px-3.5 py-2 text-sm font-medium rounded-lg transition-colors',
              isActive(href)
                ? 'text-white bg-white/10'
                : 'text-white/65 hover:text-white hover:bg-white/5',
            ]}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>

    <div class="hidden md:flex items-center gap-3">
      <a
        href={otherLangUrl}
        class="text-xs text-white/40 hover:text-white/70 transition-colors uppercase tracking-widest font-semibold"
        hreflang={otherLang}
      >
        {otherLang}
      </a>
      <a
        href={r.contact}
        class="bg-accent hover:bg-accent-dark text-white text-sm font-semibold px-4 py-2 rounded-lg transition-colors"
      >
        {t('nav.cta')}
      </a>
    </div>

    <button
      id="menu-btn"
      class="md:hidden text-white p-2 -mr-2 rounded-lg hover:bg-white/5 transition-colors"
      aria-label="Toggle menu"
      aria-expanded="false"
    >
      <svg id="icon-open" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
      <svg id="icon-close" class="w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </nav>

  <div id="mobile-menu" class="hidden md:hidden border-t border-white/10">
    <ul class="container-lg py-4 flex flex-col gap-0.5">
      {navItems.map(({ label, href }) => (
        <li>
          <a
            href={href}
            class:list={[
              'block px-3 py-2.5 text-sm font-medium rounded-lg transition-colors',
              isActive(href)
                ? 'text-white bg-white/10'
                : 'text-white/65 hover:text-white hover:bg-white/5',
            ]}
          >
            {label}
          </a>
        </li>
      ))}
      <li class="pt-3 mt-1 border-t border-white/10 flex items-center justify-between px-3">
        <a href={otherLangUrl} class="text-xs text-white/40 hover:text-white uppercase tracking-widest font-semibold">
          {otherLang}
        </a>
        <a href={r.contact} class="bg-accent text-white text-sm font-semibold px-4 py-2 rounded-lg">
          {t('nav.cta')}
        </a>
      </li>
    </ul>
  </div>
</header>

<script>
  const btn = document.getElementById('menu-btn');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('icon-open');
  const iconClose = document.getElementById('icon-close');

  btn?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden', isOpen);
    iconOpen?.classList.toggle('hidden', !isOpen);
    iconClose?.classList.toggle('hidden', isOpen);
    btn.setAttribute('aria-expanded', String(!isOpen));
  });
</script>

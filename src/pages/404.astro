---
import Base from '../layouts/Base.astro';
import AnimatedButton from '../components/ui/AnimatedButton.astro';
import { getLangFromUrl, useTranslations, routes } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const r = routes[lang];
---

<Base title={t('404.title')} description={t('404.subtitle')} lang={lang} noindex>
  <section class="hero-columns relative overflow-hidden min-h-svh flex items-center">
    <div class="container-lg relative text-center py-32">
      <p class="err-giant text-ink mb-0" aria-hidden="true">
        4<svg class="err-heart" viewBox="0 0 100 100" fill="none">
          <path
            d="M50 32 C 44 16, 22 12, 14 26 C 6 40, 16 56, 30 68 C 38 75, 46 82, 50 88 C 54 81, 63 74, 71 66 C 84 54, 94 39, 85 26 C 76 13, 55 17, 50 32 Z"
            stroke="var(--color-accent)" stroke-width="7" stroke-linecap="round" stroke-linejoin="round"
          />
        </svg>4
      </p>
      <h1 class="font-display italic font-medium text-2xl md:text-3xl text-ink mt-6 mb-0">{t('404.title')}</h1>
      <p class="text-muted mt-3 max-w-md mx-auto">{t('404.subtitle')}</p>
      <div class="mt-10 flex flex-wrap items-center justify-center gap-x-7 gap-y-4">
        <AnimatedButton href={r.home} variant="grad" size="large">{t('404.cta')}</AnimatedButton>
        <a href={r.contact} class="btn-animate-y text-sm font-semibold text-ink underline underline-offset-4">
          <span class="btn-animate-y-1">{t('nav.cta')} →</span>
          <span class="btn-animate-y-2" aria-hidden="true">{t('nav.cta')} →</span>
        </a>
      </div>
    </div>
  </section>
</Base>

<style>
  .err-giant {
    font-family: var(--font-family-display);
    font-optical-sizing: auto;
    font-weight: 850;
    font-size: clamp(6rem, 3rem + 18vw, 15rem);
    line-height: 0.9;
    letter-spacing: -0.02em;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.06em;
  }
  .err-heart {
    width: 0.62em;
    height: 0.62em;
    flex-shrink: 0;
    animation: err-beat 1.8s ease-in-out infinite;
  }
  @keyframes err-beat {
    0%, 100% { transform: scale(1); }
    12% { transform: scale(1.08); }
    24% { transform: scale(1); }
  }
  @media (prefers-reduced-motion: reduce) {
    .err-heart { animation: none; }
  }
</style>

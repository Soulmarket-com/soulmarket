---
import Base from '../../layouts/Base.astro';
import Team from '../../components/sections/Team.astro';
import CtaBanner from '../../components/sections/CtaBanner.astro';
import { useTranslations } from '../../i18n/utils';

const lang = 'en';
const t = useTranslations(lang);

const principles = [
  { title: t('about.p1.title'), text: t('about.p1.text') },
  { title: t('about.p2.title'), text: t('about.p2.text') },
  { title: t('about.p3.title'), text: t('about.p3.text') },
];

const skills = [
  'Astro.js', 'React', 'Tailwind CSS', 'WordPress', 'Figma',
  'Photoshop', 'Illustrator', 'Lightroom', 'Final Cut Pro', 'DaVinci Resolve',
  'SEO', 'Google Ads', 'Meta Ads',
];
---

<Base
  title="About us — The team behind Soulmarket"
  description="We are Soulmarket: José Miguel (development), Marcela (marketing) and Sergio (audiovisual). A small team designing websites, brands and content with soul."
  lang={lang}
>
  <header class="hero-columns relative overflow-hidden pt-28 md:pt-36 pb-10 md:pb-14">
    <div class="container-lg relative">
      <h1 class="reveal fadeInUp giant-heading text-ink mb-0">
        <em class="block">{t('about.giant.italic')}</em>
        <span class="block">{t('about.giant.main')}</span>
      </h1>
      <p class="reveal fadeInUp section-descr max-w-2xl mt-7" style="--reveal-delay:0.1s">
        {t('about.intro')}
      </p>
    </div>
  </header>

  <section class="container-lg pb-8 md:pb-12">
    <ol>
      {principles.map(({ title, text }, i) => (
        <li class="reveal fadeInUp grid md:grid-cols-[4rem_1fr_1.2fr] items-baseline gap-x-8 gap-y-2 border-t border-border py-9 md:py-12" style={`--reveal-delay:${i * 0.08}s`}>
          <span class="text-xs font-bold text-accent tracking-[0.25em]" aria-hidden="true">0{i + 1}</span>
          <h2 class="principle-title text-ink mb-0">{title}</h2>
          <p class="font-display italic text-muted text-lg mb-0">{text}</p>
        </li>
      ))}
    </ol>
  </section>

  <Team lang={lang} />

  <section class="container-lg pb-20 md:pb-28">
    <p class="reveal fadeInUp text-xs font-semibold uppercase tracking-[0.22em] text-muted mb-5">{t('about.skills')}</p>
    <div class="reveal fadeInUp flex flex-wrap gap-2" style="--reveal-delay:0.1s">
      {skills.map((skill) => (
        <span class="text-sm bg-surface border border-border text-ink px-3 py-1.5 rounded-full font-medium">{skill}</span>
      ))}
    </div>
  </section>

  <CtaBanner lang={lang} />
</Base>

<style>
  .principle-title {
    font-family: var(--font-family-display);
    font-optical-sizing: auto;
    font-weight: 850;
    font-size: clamp(1.6rem, 1.2rem + 1.8vw, 2.6rem);
    line-height: 1;
    letter-spacing: -0.015em;
    text-transform: uppercase;
  }
</style>

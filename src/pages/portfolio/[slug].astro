---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import CtaBanner from '../../components/sections/CtaBanner.astro';
import { useTranslations, routes } from '../../i18n/utils';

export async function getStaticPaths() {
  const items = await getCollection('portfolio', ({ data }) => data.lang === 'es');
  return items.map(item => ({
    params: { slug: item.id },
    props: { item },
  }));
}

const { item } = Astro.props;
const { Content } = await render(item);
const lang = 'es';
const t = useTranslations(lang);
const r = routes[lang];

const formattedDate = new Intl.DateTimeFormat('es-ES', {
  year: 'numeric', month: 'long',
}).format(item.data.date);

const categoryLabels: Record<string, string> = {
  web: t('portfolio.filter.web'),
  design: t('portfolio.filter.design'),
  'photo-video': t('portfolio.filter.media'),
  marketing: t('portfolio.filter.marketing'),
};
---

<Base
  title={item.data.title}
  description={item.data.description}
  image={item.data.image}
  lang="es"
>
  <!-- Hero -->
  <header class="bg-ink text-white pt-28 pb-16">
    <div class="container-lg">
      <a href={r.portfolio} class="inline-flex items-center gap-1.5 text-white/40 hover:text-white text-sm mb-8 transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
        {t('nav.portfolio')}
      </a>
      <div class="flex flex-wrap items-center gap-3 mb-5">
        <span class="text-xs font-medium text-accent-light bg-white/10 px-3 py-1 rounded-full">
          {categoryLabels[item.data.category]}
        </span>
        {item.data.client && (
          <span class="text-xs text-white/40">{item.data.client}</span>
        )}
        <span class="text-xs text-white/30">{formattedDate}</span>
      </div>
      <h1 class="text-4xl sm:text-5xl font-extrabold tracking-tight mb-4">{item.data.title}</h1>
      <p class="text-white/55 text-lg max-w-2xl">{item.data.description}</p>
      {item.data.url && (
        <a href={item.data.url} target="_blank" rel="noopener noreferrer"
          class="mt-6 inline-flex items-center gap-2 bg-accent hover:bg-accent-dark text-white font-semibold px-5 py-2.5 rounded-lg text-sm transition-colors">
          Ver proyecto en vivo
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
        </a>
      )}
    </div>
  </header>

  <!-- Main image -->
  <div class="container-lg -mt-8 mb-16">
    <img
      src={item.data.image}
      alt={item.data.imageAlt || item.data.title}
      class="w-full aspect-video object-cover rounded-2xl shadow-xl"
    />
  </div>

  <!-- Content -->
  <section class="container-sm pb-16 prose-content">
    <Content />
  </section>

  <!-- Tags -->
  {item.data.tags.length > 0 && (
    <div class="container-sm pb-16">
      <div class="flex flex-wrap gap-2">
        {item.data.tags.map(tag => (
          <span class="text-xs bg-surface border border-border text-muted px-3 py-1 rounded-full">{tag}</span>
        ))}
      </div>
    </div>
  )}

  <CtaBanner lang={lang} />
</Base>
